# /etc/nginx/sites-available/portfolio  →  symlink into sites-enabled/
#
# The Next.js container is published on 127.0.0.1:2000 (set in docker-compose.yml).
# nginx terminates the domain + TLS and reverse-proxies to that port.
#
#   1) Put this file at /etc/nginx/sites-available/portfolio
#   2) ln -s /etc/nginx/sites-available/portfolio /etc/nginx/sites-enabled/
#   3) nginx -t && systemctl reload nginx
#   4) certbot --nginx -d radovanrasha.com -d www.radovanrasha.com
#      (certbot rewrites this file to add the TLS/443 block automatically)

server {
    listen 80;
    listen [::]:80;

    server_name radovanrasha.com www.radovanrasha.com;

    location / {
        # 2000 = the HOST_PORT published in docker-compose.yml.
        # If you change HOST_PORT there, change it here too.
        proxy_pass http://127.0.0.1:2000;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
