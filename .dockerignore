# Dependencies & build artifacts (rebuilt inside the image)
node_modules
.next
out
build
coverage

# VCS & CI
.git
.github
.gitignore

# Local env & secrets — never bake into an image
.env
.env.*

# Editor / OS cruft
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Docs (not needed at runtime)
*.md
deploy
